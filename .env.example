# === Sanity ===
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Token dengan izin Editor untuk menulis draft dari API route (auto-artikel)
SANITY_API_WRITE_TOKEN=your_write_token

# === Anthropic (auto-artikel Claude) ===
ANTHROPIC_API_KEY=your_anthropic_key

# === Cron security ===
# Header rahasia untuk melindungi endpoint auto-artikel
CRON_SECRET=generate_a_random_string

# === Site ===
# Harus URL absolut yang valid. Satu karakter salah membuat new URL() di
# app/layout.tsx melempar, dan seluruh halaman mengembalikan 500.
NEXT_PUBLIC_SITE_URL=https://mitratelurjogja.com

# === Analytics ===
# GA4 Measurement ID (GA4 > Admin > Data Streams). Tag hanya dirender pada
# build production. Di Vercel, set variabel ini hanya untuk environment
# Production agar deploy preview tidak ikut mengirim event.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
